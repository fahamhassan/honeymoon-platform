{
  "name": "honeymoon-api",
  "version": "1.0.0",
  "description": "HoneyMoon Platform — REST API (Node.js + Express + PostgreSQL)",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "db:setup":  "psql $DATABASE_URL -f database/schema.sql",
    "db:seed":   "psql $DATABASE_URL -f database/seed.sql",
    "db:reset":  "psql $DATABASE_URL -f database/schema.sql && psql $DATABASE_URL -f database/seed.sql"
  },
  "dependencies": {
    "express":               "^4.18.2",
    "pg":                    "^8.11.3",
    "bcryptjs":              "^2.4.3",
    "jsonwebtoken":          "^9.0.2",
    "cors":                  "^2.8.5",
    "helmet":                "^7.1.0",
    "express-rate-limit":    "^7.1.5",
    "express-validator":     "^7.0.1",
    "dotenv":                "^16.3.1",
    "multer":                "^1.4.5-lts.1",
    "uuid":                  "^9.0.0",
    "morgan":                "^1.10.0",
    "compression":           "^1.7.4",
    "stripe":                "^14.18.0",
    "nodemailer":            "^6.9.7",
    "twilio":                "^4.20.0",
    "aws-sdk":               "^2.1524.0",
    "joi":                   "^17.11.0",
    "dayjs":                 "^1.11.10"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
