# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/honeymoon_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=aed

# ── PayFort (UAE) ─────────────────────────────────────────────────────────────
PAYFORT_MERCHANT_ID=your_merchant_id
PAYFORT_ACCESS_CODE=your_access_code
PAYFORT_SHA_REQUEST_PHRASE=your_sha_phrase
PAYFORT_SHA_RESPONSE_PHRASE=your_sha_phrase
PAYFORT_SANDBOX=true

# ── Twilio (OTP SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── AWS S3 (file uploads) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=me-central-1
AWS_S3_BUCKET=honeymoon-uploads

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@honeymoon.ae
EMAIL_FROM_NAME=HoneyMoon

# ── UAE Pass OAuth ────────────────────────────────────────────────────────────
UAEPASS_CLIENT_ID=your_client_id
UAEPASS_CLIENT_SECRET=your_client_secret
UAEPASS_REDIRECT_URI=https://api.honeymoon.ae/v1/auth/uaepass/callback
UAEPASS_ENV=qa   # qa | production

# ── Frontend URLs ─────────────────────────────────────────────────────────────
CLIENT_URL=https://app.honeymoon.ae
ADMIN_URL=https://admin.honeymoon.ae
VENDOR_URL=https://vendor.honeymoon.ae

# ── Platform Config ───────────────────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.05
MIN_BOOKING_VALUE=1000
DEPOSIT_PERCENTAGE=0.30
